{
  "title": "Fastscanner — Daily Collection",
  "uid": "fastscanner-daily",
  "schemaVersion": 42,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "tags": ["fastscanner"],
  "panels": [
    {
      "id": 1,
      "title": "Workers active",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(fs_daily_worker_active)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Symbols processed (5m rate)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(fs_daily_symbols_processed_total[5m])) * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "decimals": 1}}
    },
    {
      "id": 3,
      "title": "% complete",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "1 - sum(fs_daily_symbols_remaining) / clamp_min(sum(fs_daily_symbols_total), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "green", "value": 0.95}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Symbols remaining",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(fs_daily_symbols_remaining)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 5,
      "title": "ETA (seconds)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(fs_daily_symbols_remaining) / clamp_min(sum(rate(fs_daily_symbols_processed_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "title": "Total failures",
      "type": "stat",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(fs_daily_symbols_processed_total{outcome=\"failed\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 100}
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Symbols processed per minute (by worker)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (service_instance_id) (rate(fs_daily_symbols_processed_total[1m])) * 60",
          "legendFormat": "{{service_instance_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 11,
      "title": "Per-symbol duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(fs_daily_symbol_duration_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(fs_daily_symbol_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(fs_daily_symbol_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 20,
      "title": "Polygon REST p95 latency by endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (endpoint, le) (rate(fs_external_request_latency_seconds_bucket{service_role=\"daily_collection\",source=\"polygon_rest\"}[5m])))",
          "legendFormat": "{{endpoint}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 21,
      "title": "Polygon REST request rate by endpoint + status",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (endpoint, code) (rate(fs_external_requests_total{service_role=\"daily_collection\",source=\"polygon_rest\"}[1m]))",
          "legendFormat": "{{endpoint}} {{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 30,
      "title": "Rate-limiter wait p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (name, le) (rate(fs_ratelimit_wait_seconds_bucket{service_role=\"daily_collection\"}[5m])))",
          "legendFormat": "{{name}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 31,
      "title": "Polygon REST request errors (by kind)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (kind) (rate(fs_external_request_errors_total{service_role=\"daily_collection\",source=\"polygon_rest\"}[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 40,
      "title": "Cache lookups per minute (by result, freq)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (result, freq) (rate(fs_candle_partition_cache_lookup_total{service_role=\"daily_collection\"}[1m])) * 60",
          "legendFormat": "{{freq}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"stacking": {"mode": "normal"}}}}
    },
    {
      "id": 41,
      "title": "Cache hit ratio",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(fs_candle_partition_cache_lookup_total{service_role=\"daily_collection\",result=\"hit\"}[5m])) / clamp_min(sum(rate(fs_candle_partition_cache_lookup_total{service_role=\"daily_collection\"}[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.4},
              {"color": "green", "value": 0.8}
            ]
          }
        }
      }
    },
    {
      "id": 50,
      "title": "Partitions written per minute (by freq)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (freq, outcome) (rate(fs_candle_partition_write_total{service_role=\"daily_collection\"}[1m])) * 60",
          "legendFormat": "{{freq}} {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    },
    {
      "id": 51,
      "title": "CSV write latency p95 (by freq)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (freq, le) (rate(fs_candle_partition_write_duration_seconds_bucket{service_role=\"daily_collection\"}[5m])))",
          "legendFormat": "{{freq}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 60,
      "title": "Failures by kind (5m rate)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 44},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (kind) (rate(fs_daily_symbol_failures_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"stacking": {"mode": "normal"}}}}
    },
    {
      "id": 61,
      "title": "Symbols processed (cumulative, by outcome)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 44},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (outcome) (fs_daily_symbols_processed_total)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "none"}}
    }
  ]
}
